<Application x:Class="PsyDiagnostics.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PsyDiagnostics.ViewModels"
             xmlns:helpers="clr-namespace:PsyDiagnostics.Helpers"
             xmlns:views="clr-namespace:PsyDiagnostics.Views"
             StartupUri="MainWindow.xaml">

    <Application.Resources>

        <helpers:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
        
        <DataTemplate DataType="{x:Type vm:ParticipantViewModel}">
            <views:ParticipantView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TestSelectionViewModel}">
            <views:TestSelectionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TestViewModel}">
            <views:TestView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
    </Application.Resources>
</Application>