<Window x:Class="PsyDiagnostics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace=PsyDiagnostics.Views"
        Title="PsyDiagnostics"
        Height="600"
        Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF1E1E28"
        Foreground="#FFF5F5F7">   <!-- ВАЖНО -->

    <Grid Background="#FF1E1E28">
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>