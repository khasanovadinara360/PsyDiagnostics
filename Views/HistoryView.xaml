<UserControl x:Class="PsyDiagnostics.Views.HistoryView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20">

        <TextBlock Text="История" FontSize="22"/>

        <TextBox Width="200" Text="{Binding SearchId}" Margin="5"/>

        <Button Content="Найти"
                Command="{Binding SearchCommand}"
                Margin="5"/>

        <DataGrid ItemsSource="{Binding Results}" Height="200"/>
    </StackPanel>
</UserControl>