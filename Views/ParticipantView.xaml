<UserControl x:Class="PsyDiagnostics.Views.ParticipantView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="ValidatedTextBox" TargetType="TextBox">
            <Setter Property="Margin" Value="0 3"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self},
                            Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔍 ПОИСК -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="ID"/>

            <TextBox Text="{Binding DataContext.SearchId, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5"
                     Width="200"/>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <Button Content="Найти" Command="{Binding DataContext.SearchCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="5"/>
                <Button Content="Сохранить" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="5"/>
            </StackPanel>

        </StackPanel>

        <!-- 📋 ОСНОВНАЯ ФОРМА -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <TabControl Margin="10">

                <!-- ЛИЧНЫЕ -->
                <TabItem Header="Личные">
                    <StackPanel Margin="10">

                        <TextBlock Text="ФИО"/>
                        <TextBox Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding CurrentParticipant.FullName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Дата рождения"/>
                        <DatePicker SelectedDate="{Binding CurrentParticipant.BirthDate}"/>

                        <TextBlock Text="Возраст"/>
                        <TextBox Text="{Binding CurrentParticipant.Age, Mode=OneWay}" IsReadOnly="True"/>

                        <TextBlock Text="Место рождения"/>
                        <TextBox Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding CurrentParticipant.BirthPlace, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Гражданство"/>
                        <ComboBox ItemsSource="{Binding DataContext.Citizenships, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.Citizenship}"/>

                    </StackPanel>
                </TabItem>

                <!-- СОЦ -->
                <TabItem Header="Социальные">
                    <StackPanel Margin="10">

                        <TextBlock Text="Образование"/>
                        <ComboBox ItemsSource="{Binding DataContext.EducationLevels, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.EducationLevel}"/>

                        <TextBlock Text="Семейное положение"/>
                        <ComboBox ItemsSource="{Binding DataContext.MaritalStatuses, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.MaritalStatus}"/>

                        <CheckBox Content="Есть дети"
                                  IsChecked="{Binding CurrentParticipant.HasChildren}"/>

                        <TextBlock Text="Профессия"/>
                        <TextBox Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding CurrentParticipant.ProfessionBeforeConviction, UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>
                </TabItem>

                <!-- 🔥 КРИМИНАЛ -->
                <TabItem Header="Криминальные">
                    <StackPanel Margin="10">

                        <!-- 🔍 ПОИСК СТАТЬИ -->
                        <TextBlock Text="Статья"/>

                        <TextBox Width="250"
                                 Margin="0,5"
                                 Text="{Binding DataContext.ArticleSearch, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>

                        <ListBox ItemsSource="{Binding DataContext.FilteredArticles, RelativeSource={RelativeSource AncestorType=Window}}"
                                 SelectedItem="{Binding DataContext.SelectedArticle, RelativeSource={RelativeSource AncestorType=Window}}"
                                 MaxHeight="150"
                                 BorderBrush="Gray"
                                 BorderThickness="1"
                                 Margin="0,5">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" Padding="5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>

                        <!-- ЧАСТЬ -->
                        <TextBlock Text="Часть"/>
                        <ComboBox ItemsSource="{Binding DataContext.AvailableParts, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.ArticlePart}"
                                  Margin="0,5"/>

                        <!-- ПУНКТ -->
                        <TextBlock Text="Пункт"/>
                        <ComboBox ItemsSource="{Binding DataContext.AvailablePoints, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.ArticlePoint}"
                                  Margin="0,5"/>

                        <!-- ГОТОВАЯ СТАТЬЯ -->
                        <TextBlock Text="{Binding CurrentParticipant.CriminalArticle}"
                                   FontWeight="Bold"
                                   Foreground="Blue"
                                   Margin="0,10"/>

                        <!-- СРОК -->
                        <TextBlock Text="Срок (лет)"/>
                        <TextBox Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding CurrentParticipant.SentenceTerm, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,5"/>

                        <TextBlock Text="{Binding CurrentParticipant.SentenceTermDisplay}"
                                   Foreground="Blue"
                                   FontWeight="Bold"
                                   Margin="0,5"/>

                        <!-- ТИП -->
                        <TextBlock Text="Тип преступления"/>
                        <ComboBox ItemsSource="{Binding DataContext.CrimeTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.CrimeType}"
                                  Margin="0,5"/>

                        <!-- РЕЦИДИВ -->
                        <TextBlock Text="Рецидив"/>
                        <ComboBox ItemsSource="{Binding DataContext.Recidivisms, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.Recidivism}"
                                  Margin="0,5"/>

                        <!-- ОТРЯД -->
                        <TextBlock Text="Отряд"/>
                        <TextBox Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding CurrentParticipant.Unit, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,5"/>

                        <!-- КАТЕГОРИЯ -->
                        <TextBlock Text="Категория"/>
                        <ComboBox ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding CurrentParticipant.Category}"
                                  Margin="0,5"/>

                        <!-- ТЕСТ -->
                        
                        <Button Content="Перейти к тестированию"
                                Height="40"
                                Margin="0 20 0 0"
                                Command="{Binding GoToTestCommand}"/>

                    </StackPanel>
                </TabItem>

            </TabControl>

        </ScrollViewer>

    </Grid>
</UserControl>