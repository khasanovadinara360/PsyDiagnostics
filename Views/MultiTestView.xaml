<UserControl x:Class="PsyDiagnostics.Views.MultiTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PsyDiagnostics.ViewModels"
             xmlns:views="clr-namespace:PsyDiagnostics.Views">

    <Grid Background="#1E1E2F">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- основное содержимое (левый список + TestView) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#232336">
                <ListBox ItemsSource="{Binding TestViewModels}"
                         SelectedItem="{Binding CurrentTest}"
                         Margin="5"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding TestTitle}"
                                    Margin="2"
                                    Padding="8,4"
                                    Command="{Binding DataContext.SelectTestCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentTest}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:TestViewModel}">
                        <views:TestView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- нижняя панель: кнопка На главную только после завершения всех тестов -->
        <DockPanel Grid.Row="1" Margin="10">
            <Button Content="На главную"
                    Command="{Binding DataContext.GoHomeCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                    HorizontalAlignment="Left"
                    Padding="15,8">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CanGoHomeAfterTests,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DockPanel>
    </Grid>
</UserControl>