<UserControl x:Class="PsyDiagnostics.Views.ResultView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20">

        <TextBlock Text="Результат" FontSize="22"/>

        <TextBlock Text="{Binding Risk}" Margin="20"/>

        <Button Content="История"
                Command="{Binding ToHistoryCommand}"/>
    </StackPanel>
</UserControl>