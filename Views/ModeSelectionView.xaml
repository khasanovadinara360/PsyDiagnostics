<UserControl x:Class="PsyDiagnostics.Views.ModeSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgMainColor" Color="#FF1E1E28"/>
        <SolidColorBrush x:Key="BgCardColor" Color="#FF252532"/>
        <SolidColorBrush x:Key="BorderColor" Color="#FF323244"/>
        <SolidColorBrush x:Key="AccentColor" Color="#FF4E5DFF"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#FFF5F5F7"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#FF9FA4B5"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="Background" Value="{StaticResource BgCardColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SubtitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgMainColor}" Margin="20">
        <Border Background="{StaticResource BgCardColor}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="420">

            <StackPanel>
                <TextBlock Text="Выбор режима тестирования"
                           Style="{StaticResource TitleText}"/>

                <TextBlock Text="Выберите формат прохождения тестов"
                           Style="{StaticResource SubtitleText}"/>

                <Button Content="Экспресс режим"
                        Command="{Binding SelectExpressCommand}"
                        Background="{StaticResource AccentColor}"
                        BorderBrush="Transparent"/>

                <Button Content="Полный режим"
                        Command="{Binding SelectFullCommand}"/>

                <Separator Margin="0,8,0,16"
                           Background="{StaticResource BorderColor}"/>

                <Button Content="Назад"
                        Command="{Binding BackCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>