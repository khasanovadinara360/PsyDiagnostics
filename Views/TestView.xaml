<UserControl x:Class="PsyDiagnostics.Views.TestView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1E1E2F">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Margin="10">
            <TextBlock Text="{Binding TestTitle}" FontSize="20" Foreground="White"/>
            <ProgressBar Maximum="{Binding TotalQuestions}" Value="{Binding CurrentIndex, Mode=OneWay}"/>
        </StackPanel>

        <!-- QUESTION -->
        <StackPanel Grid.Row="1" Margin="20">
            <TextBlock Text="{Binding QuestionNumber}" Foreground="Gray"/>
            <TextBlock Text="{Binding CurrentQuestion.Text}" FontSize="18" Foreground="White" Margin="0,10"/>

            <ItemsControl ItemsSource="{Binding CurrentQuestion.Answers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <RadioButton Content="{Binding Text}"
                                     GroupName="Answers"
                                     Foreground="White"
                                     Margin="5"
                                     IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Назад" Command="{Binding PrevCommand}" Margin="5"/>
            <Button Content="{Binding NextButtonText}" Command="{Binding NextCommand}" Margin="5"/>
        </StackPanel>

    </Grid>
</UserControl>