<UserControl x:Class="PsyDiagnostics.Views.TestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1E1E2F">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок теста, формат и прогресс -->
        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="{Binding TestTitle}"
                       FontSize="20"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding ModeTitle}"
                       FontSize="14"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,6"/>

            <ProgressBar Maximum="{Binding TotalQuestions}"
                         Value="{Binding CurrentIndex, Mode=OneWay}"
                         Margin="0,5"/>
        </StackPanel>

        <!-- Вопрос -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="20">
            <TextBlock Text="{Binding QuestionNumber}"
                       Foreground="Gray"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentQuestion.Text}"
                       FontSize="20"
                       Foreground="White"
                       Margin="0,10,0,20"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="600"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Ответы -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding CurrentQuestion.Answers}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Text}"
                            Foreground="White"
                            Background="#2C2C40"
                            BorderBrush="#4A4A6A"
                            BorderThickness="2"
                            Margin="5"
                            Padding="15,12"
                            Width="400"
                            HorizontalAlignment="Center"
                            Command="{Binding SelectAnswerCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#2C2C40"/>
                                <Setter Property="BorderBrush" Value="#4A4A6A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="Background" Value="#3A3A60"/>
                                        <Setter Property="BorderBrush" Value="#6A6AC0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Нижняя панель: слева На главную (после результатов), справа Завершить -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="На главную"
                    Command="{Binding DataContext.GoHomeCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                    HorizontalAlignment="Left"
                    Padding="15,8">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.CanGoHomeAfterTests,
                                                       RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Content="Завершить"
                    Padding="15,8"
                    Background="#4060C0"
                    Foreground="White"
                    BorderBrush="#4060C0"
                    Visibility="{Binding FinishButtonVisibility}"
                    Command="{Binding FinishCommand}"
                    HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>